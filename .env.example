# Which backend serves the vision model for AI triage:
#   lmstudio   = local LM Studio server (default)
#   openrouter = hosted models via https://openrouter.ai
LLM_PROVIDER=lmstudio

# ---- LM Studio (LLM_PROVIDER=lmstudio) ----

# LM Studio OpenAI-compatible base URL (note the trailing /v1)
LMSTUDIO_BASE_URL=http://localhost:1234/v1

# Vision-capable model identifier loaded in LM Studio.
# Use a capable vision model; small (<7B) models are unreliable for structured output.
LMSTUDIO_MODEL=google/gemma-4-12b

# Optional API token (only needed if you enabled auth in LM Studio's Developer settings).
LMSTUDIO_API_TOKEN=

# ---- OpenRouter (LLM_PROVIDER=openrouter) ----

# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Any vision-capable OpenRouter model slug, e.g.:
#   google/gemini-2.5-flash, anthropic/claude-sonnet-4.5, qwen/qwen3-vl-235b-a22b-instruct
OPENROUTER_MODEL=google/gemini-2.5-flash

# Comparison server port
PORT=3100

# Pixel diff thresholds (fraction of total pixels, 0..1).
# diffRatio <= PIXEL_THRESHOLD  -> instant PASS (no model call)
# diffRatio >= MAX_RATIO        -> instant FAIL (no model call)
# in between                    -> AI vision triage decides
PIXEL_THRESHOLD=0.001
MAX_RATIO=0.5

# pixelmatch per-pixel color sensitivity, 0..1 (lower = stricter)
PIXEL_MATCH_THRESHOLD=0.1

# ---- AI triage tuning ----

# Longest image edge (px) sent to the vision model; larger screenshots are
# downscaled with a quality filter for predictable model input. 0 disables.
AI_MAX_IMAGE_DIM=2048

# Retries for transient model-call failures (network, 5xx, 429).
AI_RETRIES=2

# AI verdicts below this confidence are flagged needsReview=true.
AI_REVIEW_CONFIDENCE=0.6

# When true (and LLM_PROVIDER=lmstudio), the server warms (loads) the vision
# model on startup via LM Studio's native API.
WARM_MODEL_ON_START=false

# Client-side: where the Playwright helper sends comparison requests.
COMPARE_SERVER_URL=http://localhost:3100

# Client-side: set to 1 to (re)write baselines instead of asserting.
UPDATE_BASELINES=
